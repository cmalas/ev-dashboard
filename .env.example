# Copy this file to .env and fill in your actual values.
# NEVER commit .env to git — it is gitignored.

# ── Required ────────────────────────────────────────────────────────────────

# The Odds API key (https://the-odds-api.com)
ODDS_API_KEY=your_odds_api_key_here

# PostgreSQL password (choose anything strong)
POSTGRES_PASSWORD=change_me_to_something_strong

# ── Polling ─────────────────────────────────────────────────────────────────

# Dynamic interval bounds — the poller calculates an optimal interval each
# cycle based on remaining API credits and days until the next monthly reset
# (1st of month, 00:00 UTC). The result is clamped to these limits.
MIN_POLL_INTERVAL_SECONDS=600    # 10 min floor
MAX_POLL_INTERVAL_SECONDS=3600   # 60 min ceiling

# Fallback interval used only if credit data is unavailable (seconds)
POLL_INTERVAL_SECONDS=1800

# Your Odds API monthly credit quota (used for dynamic interval budgeting)
ODDS_API_QUOTA=20000

# Quiet hours — poller slows to QUIET_POLL_INTERVAL during this window.
# Times are in America/Chicago (CT). Set both to the same value to disable.
QUIET_HOURS_START=0
QUIET_HOURS_END=8
QUIET_POLL_INTERVAL=7200

# ── Props ───────────────────────────────────────────────────────────────────

# Only fetch props for games starting within this many hours
PROPS_HOURS_AHEAD=24

# Fetch props every N mainline cycles (default 6 = every ~1 hr at 10-min polling)
# Props cost ~12 credits/game × ~15 MLB games ≈ 180 credits/props cycle.
# Increase this value if you're hitting your monthly credit limit.
PROPS_CYCLE_INTERVAL=6

# ── Networking (change only if defaults conflict with existing services) ─────

NGINX_PORT=8765
POSTGRES_HOST=postgres
POSTGRES_DB=evdashboard
POSTGRES_USER=evuser
REDIS_HOST=redis
