# Copy this file to .env and fill in your actual values.
# NEVER commit .env to git — it is gitignored.

# Required: The Odds API key (https://the-odds-api.com)
ODDS_API_KEY=your_odds_api_key_here

# Required: PostgreSQL password (choose anything strong)
POSTGRES_PASSWORD=change_me_to_something_strong

# Optional overrides (defaults shown)
POLL_INTERVAL_SECONDS=1800
NGINX_PORT=8765

# Quiet hours -- poller slows to QUIET_POLL_INTERVAL during this window
QUIET_HOURS_START=2
QUIET_HOURS_END=9
QUIET_POLL_INTERVAL=7200
